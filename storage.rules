rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil de usuario
    // Path: users/{uid}/profile.jpg
    match /users/{uid}/{fileName} {
      // Solo el propio usuario puede leer/escribir su foto
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null &&
                      request.auth.uid == uid &&
                      request.resource.size < 5 * 1024 * 1024 && // Máx 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Avatar del hogar
    // Path: homes/{homeId}/avatar.jpg
    // Lectura abierta a cualquier miembro autenticado del hogar (en
    // Firestore se verifica vía `homes/{homeId}/members/{uid}`); aquí
    // permitimos read a cualquier autenticado porque el bucket no tiene
    // acceso al doc Firestore. La URL llevará un token de descarga
    // protegido por Firebase Storage; tareas/cards usan esa URL.
    function isHomeAdminOrOwner(homeId) {
      // Las Storage rules pueden consultar Firestore. Verificamos que el usuario
      // sea admin/owner del hogar leyendo su membership. Cierra el agujero de
      // que cualquier autenticado pudiera sobrescribir/borrar el avatar de
      // cualquier hogar conociendo el homeId.
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/memberships/$(homeId)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)/memberships/$(homeId)).data.role in ['owner', 'admin'];
    }

    match /homes/{homeId}/{fileName} {
      // Lectura: cualquier autenticado (la URL lleva token de descarga).
      allow read: if request.auth != null;
      // Escritura/borrado: solo admin/owner del hogar (verificado en Firestore).
      allow write: if isHomeAdminOrOwner(homeId) &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
      allow delete: if isHomeAdminOrOwner(homeId);
    }

    // Cualquier otro path: denegado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isMemberOfHome(homeId) {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(homeId));
    }

    function getMembership(homeId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(homeId)).data;
    }

    function isActiveMember(homeId) {
      return isMemberOfHome(homeId) && getMembership(homeId).status == 'active';
    }

    // Acceso de lectura al hogar: cualquier membresía cuyo status NO sea 'left'.
    // Admite 'active' y 'frozen' (y memberships legacy sin campo status, por
    // compatibilidad), pero EXCLUYE a los miembros que salieron/fueron expulsados
    // (status == 'left'), cuya membership se conserva para poder reincorporarlos
    // (reinstateMember) pero NO debe seguir dando acceso a los datos del hogar.
    // OJO: al congelar (apply_downgrade_plan) solo cambia el doc de miembro a
    // 'frozen'; la membership de users/{uid} sigue 'active', así que los frozen
    // conservan lectura por ambas vías.
    function isCurrentMember(homeId) {
      return isMemberOfHome(homeId) && getMembership(homeId).status != 'left';
    }

    function isAdminOrOwner(homeId) {
      return isMemberOfHome(homeId) && getMembership(homeId).role in ['owner', 'admin'];
    }

    function isOwner(homeId) {
      return isMemberOfHome(homeId) && getMembership(homeId).role == 'owner';
    }

    // ─── Premium / límites Free ────────────────────────────────────────────────
    // Valores persistidos canónicos: active, cancelledPendingEnd, rescue.
    // También se aceptan variantes legacy snake_case durante la migración.

    function isPremiumStatus(status) {
      return status in [
        'active',
        'cancelledPendingEnd',
        'cancelled_pending_end',
        'rescue'
      ];
    }

    function isHomePremium(homeId) {
      return isPremiumStatus(
        get(/databases/$(database)/documents/homes/$(homeId)).data.premiumStatus
      );
    }

    // ─── Task write hardening ─────────────────────────────────────────────────
    // El ALTA de tareas va exclusivamente por la callable `createTask`
    // (límite Free no eludible, Hallazgo #14). Aquí solo se endurece el UPDATE
    // que sigue siendo client-side (edición / freeze / soft-delete).

    function taskUpdateFieldsAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'title',
        'description',
        'visualKind',
        'visualValue',
        'recurrenceType',
        'recurrenceRule',
        'assignmentMode',
        'assignmentOrder',
        'currentAssigneeUid',
        'nextDueAt',
        'difficultyWeight',
        'updatedAt',
        'onMissAssign',
        'status',
        'frozenUids',
        'deletedAt'
      ]);
    }

    function taskUpdateValuesAllowed() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
        || request.resource.data.status in ['active', 'frozen', 'deleted'];
    }

    // La distribución inteligente (assignmentMode == 'smartDistribution') es una
    // feature Premium. En CREATE el gate vive en la callable `createTask`.
    // En UPDATE: cambiar a smart requiere Premium, pero conservar un smart ya
    // existente (o pasar a básico) siempre se permite, para no bloquear la
    // edición de una tarea tras un downgrade del hogar.
    function taskUpdateSmartAllowed(homeId) {
      return request.resource.data.assignmentMode != 'smartDistribution'
        || resource.data.assignmentMode == 'smartDistribution'
        || isHomePremium(homeId);
    }

    // ─── Idiomas (pública) ──────────────────────────────────────────────────────

    match /languages/{code} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Usuarios ──────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Documento privado: puede contener teléfono, preferencias, billing,
      // contadores de plazas y otros datos sensibles. Los perfiles visibles se
      // sirven desde homes/{homeId}/members/{uid} y dashboard denormalizado.
      allow read: if isUser(uid);
      allow create: if isUser(uid)
        && !request.resource.data.keys().hasAny([
          'baseHomeSlots',
          'lifetimeUnlockedHomeSlots',
          'homeSlotCap',
          'baseSlots',
          'lifetimeUnlocked'
        ]);
      allow update: if isUser(uid) && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny([
                         'baseHomeSlots',
                         'lifetimeUnlockedHomeSlots',
                         'homeSlotCap',
                         'baseSlots',
                         'lifetimeUnlocked'
                       ]);
      allow delete: if false; // Solo via Function

      match /memberships/{homeId} {
        allow read: if isUser(uid);
        allow write: if false; // Solo via Functions
      }

      match /slotLedger/{unlockId} {
        allow read: if isUser(uid);
        allow write: if false; // Solo via Functions
      }
    }

    // ─── Hogares ───────────────────────────────────────────────────────────────

    match /homes/{homeId} {
      // Solo miembros vigentes pueden leer el hogar (incluyendo congelados,
      // excluyendo a quienes salieron/fueron expulsados — status 'left').
      allow read: if isCurrentMember(homeId);
      allow create: if false; // Solo via Functions
      allow update: if isAdminOrOwner(homeId) &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['ownerUid', 'currentPayerUid', 'premiumStatus', 'premiumEndsAt',
                                'lifetimeUnlockedHomeSlots']);
      allow delete: if false;

      // Dashboard: lectura para miembros vigentes, escritura solo Functions
      match /views/dashboard {
        allow read: if isCurrentMember(homeId);
        allow write: if false;
      }

      // Miembros del hogar
      match /members/{uid} {
        allow read: if isCurrentMember(homeId);
        // Members may only update their own notificationPrefs and vacation fields
        allow update: if isUser(uid) && isCurrentMember(homeId) &&
                         request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['notificationPrefs', 'vacation']);
        allow write: if false; // Solo via Functions
      }

      // Tareas
      match /tasks/{taskId} {
        allow read: if isCurrentMember(homeId);
        // Create: SOLO vía la callable `createTask` (Hallazgo #14). El límite
        // del plan Free no puede vivir en reglas porque éstas no cuentan
        // documentos: leían un contador denormalizado y eventual
        // (`views/dashboard.planCounters`) que una ráfaga de altas eludía. La
        // callable cuenta las tareas activas reales de forma transaccional.
        allow create: if false;
        // Update cliente: solo configuración editable por admin/owner. Campos
        // derivados/auditoría (completedCount90d, createdByUid, createdAt,
        // homeId) quedan reservados a Cloud Functions/Admin SDK.
        allow update: if isAdminOrOwner(homeId) && isActiveMember(homeId)
                         && taskUpdateFieldsAllowed()
                         && taskUpdateValuesAllowed()
                         && taskUpdateSmartAllowed(homeId);
        allow delete: if false; // Soft delete via update
      }

      // Eventos de tarea
      match /taskEvents/{eventId} {
        allow read: if isCurrentMember(homeId);
        allow write: if false; // Solo via Functions

        // Valoraciones — solo lectura restringida
        match /reviews/{reviewerUid} {
          // El autor y el evaluado pueden leer
          allow read: if isAuth() && (
            request.auth.uid == reviewerUid ||
            request.auth.uid == get(/databases/$(database)/documents/homes/$(homeId)/taskEvents/$(eventId)).data.performerUid
          );
          allow write: if false; // Solo via Functions
        }
      }

      // Estadísticas por miembro y tarea
      match /memberTaskStats/{statId} {
        allow read: if isCurrentMember(homeId);
        allow write: if false; // Solo via Functions
      }

      // Registro de eventos valorados por miembro (para isRated checks)
      match /memberReviews/{uid} {
        allow read: if isUser(uid) && isMemberOfHome(homeId);
        allow write: if false; // Solo via Functions
      }

      // Plan de downgrade — solo owner
      match /downgrade/current {
        allow read: if isOwner(homeId);
        allow write: if isOwner(homeId); // Owner puede escribir el plan manual
      }

      // Historial de suscripciones
      match /subscriptions/{chargeId} {
        allow read: if isCurrentMember(homeId) && getMembership(homeId).billingState in ['currentPayer', 'formerPayer'];
        allow write: if false;

        match /charges/{nestedChargeId} {
          allow read: if isCurrentMember(homeId) && getMembership(homeId).billingState in ['currentPayer', 'formerPayer'];
          allow write: if false;
        }
      }

      // Invitaciones
      match /invitations/{inviteId} {
        // Solo admin/owner del propio hogar pueden leer/listar invitaciones.
        // La unión por código va por la callable joinHomeByCode (Admin SDK,
        // server-side), así que el cliente NUNCA necesita leer invitaciones de
        // otros hogares. (Antes: lectura pública por código + collectionGroup
        // list:isAuth permitían enumerar TODOS los códigos del sistema.)
        allow read: if isAdminOrOwner(homeId);
        allow create: if isAdminOrOwner(homeId) && isActiveMember(homeId);
        allow update: if isAdminOrOwner(homeId) && isActiveMember(homeId);
        allow delete: if isAdminOrOwner(homeId) && isActiveMember(homeId);
      }

      // Metadatos del sistema
      match /system/meta {
        allow read: if isCurrentMember(homeId);
        allow write: if false;
      }
    }

    // Collection group sobre invitations: PROHIBIDO desde el cliente.
    // Antes `allow list: if isAuth()` permitía a cualquier autenticado enumerar
    // TODOS los códigos de invitación del sistema. La unión por código se hace
    // exclusivamente por la callable joinHomeByCode (Admin SDK, con rate-limit),
    // que resuelve el código server-side; el cliente no consulta invitations.
    match /{path=**}/invitations/{inviteId} {
      allow list: if false;
    }

    // Collection group para valoraciones (perfil de miembro + isRated).
    // Privacidad (regla de negocio #8): solo el autor (reviewerUid) o el
    // evaluado (performerUid) pueden leer una valoración. Las queries del
    // cliente (memberVisibleReviews) filtran por uno de esos campos, así que
    // Firestore valida estáticamente que todo resultado cumple la condición.
    match /{path=**}/reviews/{reviewId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.reviewerUid ||
        request.auth.uid == resource.data.performerUid
      );
    }
  }
}

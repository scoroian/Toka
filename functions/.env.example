# Template de variables de entorno de Cloud Functions.
# Copia este fichero como:
#   - .env.local          в†’ para desarrollo local (firebase emulators:start)
#   - .env.<projectId>    в†’ para despliegue a ese proyecto (ej. .env.toka-dd241)
# Firebase CLI los auto-carga al ejecutar emulators o firebase deploy.
# Los .env.* (excepto este) estГЎn en .gitignore.

# в”Ђв”Ђв”Ђ VerificaciГіn de recibos IAP (syncEntitlement) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Config NO sensible aquГ­; el MATERIAL SENSIBLE va en Secret Manager:
#   - GOOGLE_PLAY_SA_JSON     в†’ JSON de service account con scope androidpublisher
#   - APP_STORE_PRIVATE_KEY   в†’ contenido de la clave .p8 de App Store Connect
# Setearlos con:  firebase functions:secrets:set <NOMBRE>
# (estГЎn enlazados en el `secrets:[...]` de syncEntitlement).
#
# Si NO hay verificador configurado (faltan estos valores), en producciГіn la
# callable se BLOQUEA (no activa Premium); en emulador cae a inferencia.

# Android (Google Play Developer API)
GOOGLE_PLAY_PACKAGE_NAME=

# iOS (App Store Server API)
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
APP_STORE_BUNDLE_ID=
APP_STORE_ENV=Production

# Defensa en profundidad: en true, sin verificador configurado NO se infiere
# (rechaza). En producciГіn dГ©jalo en true.
STRICT_RECEIPT_VALIDATION=true

# в”Ђв”Ђв”Ђ ReconciliaciГіn con stores: RTDN + App Store Notifications (premortem #06) в”Ђ
# Topic de Cloud Pub/Sub donde Google Play publica las Real-time Developer
# Notifications (RTDN). Debe COINCIDIR con el topic configurado en Play Console
# (Monetization setup в†’ Real-time developer notifications). El handler
# `googlePlayRtdnHandler` se suscribe a este topic. Default: `play-rtdn`.
GOOGLE_RTDN_TOPIC=play-rtdn
#
# App Store Server Notifications v2 (Apple) NO usan Pub/Sub: Apple las entrega
# por WEBHOOK HTTPS. Configura la URL del endpoint `appStoreServerNotificationsHandler`
# (la imprime `firebase deploy`) en App Store Connect в†’ App Information в†’
# App Store Server Notifications (Production/Sandbox). El handler filtra por
# APP_STORE_BUNDLE_ID (arriba) para descartar payloads ajenos.

# в”Ђв”Ђв”Ђ Banner AdMob (premortem #05) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Unit IDs REALES del banner por plataforma. NO son secretos (van embebidos en
# el cliente), por eso van aquГ­ y no en Secret Manager. El backend los inyecta
# en homes/{homeId}/views/dashboard.adFlags (bannerUnitAndroid/bannerUnitIos) y
# el cliente toma el de su plataforma.
#
# Si se dejan VACГЌOS, el backend cae a los unit IDs de PRUEBA de Google
# (seguros en dev, cero revenue). NUNCA deben llegar a una release.
ADMOB_BANNER_UNIT_ANDROID=
ADMOB_BANNER_UNIT_IOS=

# Pon esto a `true` SOLO en el .env del proyecto de PRODUCCIГ“N real. Entonces el
# guardrail `npm run check:release-safety` (que corre en `npm run deploy`)
# bloquea el deploy si los units de arriba estГЎn vacГ­os o son de prueba.
# DГ©jalo sin definir / false en los proyectos de dev (p. ej. toka-dd241).
TOKA_REQUIRE_REAL_AD_UNITS=false

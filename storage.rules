rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil de usuario
    // Path: users/{uid}/profile.jpg
    match /users/{uid}/{fileName} {
      // Solo el propio usuario puede leer/escribir su foto
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null &&
                      request.auth.uid == uid &&
                      request.resource.size < 5 * 1024 * 1024 && // Máx 5MB
                      request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Avatar del hogar
    // Path: homes/{homeId}/avatar.jpg
    // Lectura abierta a cualquier miembro autenticado del hogar (en
    // Firestore se verifica vía `homes/{homeId}/members/{uid}`); aquí
    // permitimos read a cualquier autenticado porque el bucket no tiene
    // acceso al doc Firestore. La URL llevará un token de descarga
    // protegido por Firebase Storage; tareas/cards usan esa URL.
    match /homes/{homeId}/{fileName} {
      allow read: if request.auth != null;
      // Solo autenticados pueden subir; el límite real (admin/owner)
      // lo aplican las reglas Firestore al actualizar `homes/{homeId}.photoUrl`.
      // Tamaño: 5 MB máx; tipo: imagen.
      allow write: if request.auth != null &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Cualquier otro path: denegado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
